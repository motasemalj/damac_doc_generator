generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects     Project[]
  templates    Template[]
  sessions     Session[]
  auditLogs    AuditLog[]
  tddDocuments TddDocument[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  csrfToken String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id                       String   @id @default(cuid())
  userId                   String
  name                     String
  description              String?
  contextFileInstructions  String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots Snapshot[]
  contextFiles ProjectContextFile[]
  tdds      TddDocument[]
  jobs      GenerationJob[]

  @@index([userId, updatedAt])
}

model Snapshot {
  id               String   @id @default(cuid())
  projectId        String
  storagePath      String
  originalFileName String
  fileSizeBytes    Int
  fileCount        Int      @default(0)
  createdAt        DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tdds    TddDocument[]
  jobs    GenerationJob[]

  @@index([projectId, createdAt])
}

model ProjectContextFile {
  id               String   @id @default(cuid())
  projectId        String
  storagePath      String
  originalFileName String
  mimeType         String?
  fileSizeBytes    Int
  extractedText    String   @default("")
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Template {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  description     String?
  promptText      String
  variablesSchema  String   @default("[]")
  sectionsSchema   String   @default("[]")
  isDefault        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  tdds TddDocument[]
  jobs GenerationJob[]

  @@index([userId, updatedAt])
  @@index([isDefault, updatedAt])
}

model TddDocument {
  id              String   @id @default(cuid())
  userId          String?
  projectId       String?
  snapshotId      String?
  templateId      String?
  title           String
  description     String?
  tags            String   @default("[]")
  markdownContent String   @default("")
  generationNotes String?
  source          String   @default("generated")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshot  Snapshot?     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  template  Template?     @relation(fields: [templateId], references: [id])
  revisions TddRevision[]
  jobs      GenerationJob[]

  @@index([userId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([snapshotId])
  @@index([templateId])
}

model TddRevision {
  id              String   @id @default(cuid())
  tddDocumentId   String
  markdownContent String
  message         String?
  createdAt       DateTime @default(now())

  tddDocument TddDocument @relation(fields: [tddDocumentId], references: [id], onDelete: Cascade)

  @@index([tddDocumentId, createdAt])
}

model GenerationJob {
  id              String   @id @default(cuid())
  tddDocumentId   String?
  projectId       String
  snapshotId      String
  templateId      String
  status          String   @default("pending")
  generationNotes String?
  startedAt       DateTime?
  finishedAt      DateTime?
  errorMessage    String?
  tokensIn        Int?
  tokensOut       Int?
  createdAt       DateTime @default(now())

  tddDocument TddDocument? @relation(fields: [tddDocumentId], references: [id], onDelete: SetNull)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshot    Snapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  template    Template     @relation(fields: [templateId], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, status, createdAt])
  @@index([snapshotId])
  @@index([templateId])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  metadata     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
